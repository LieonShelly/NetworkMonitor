# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:ios)

platform :ios do
  desc "Description of what the lane does"
  lane :custom_lane do
    # add actions here: https://docs.fastlane.tools/actions
  end

  desc "格式化 SVG imageset 的 Contents.json，移除多余的 scale 条目，只保留一个 universal 条目"
  lane :format_svg_imagesets do
    require 'json'
    require 'find'

    assets_path = File.expand_path("../LTApp/Resource/Assets.xcassets", __dir__)

    unless Dir.exist?(assets_path)
      UI.user_error!("Assets.xcassets 目录不存在: #{assets_path}")
    end

    formatted_count = 0
    skipped_count = 0

    # 遍历所有 .imageset 目录
    Find.find(assets_path) do |path|
      next unless File.directory?(path) && path.end_with?('.imageset')

      contents_file = File.join(path, 'Contents.json')
      next unless File.exist?(contents_file)

      begin
        contents = JSON.parse(File.read(contents_file))
      rescue JSON::ParserError => e
        UI.important("JSON 解析失败，跳过: #{contents_file} (#{e.message})")
        skipped_count += 1
        next
      end

      images = contents['images']
      next unless images.is_a?(Array)

      # 找到包含 .svg 文件名的条目
      svg_entry = images.find { |img| img['filename']&.end_with?('.svg') }

      # 如果没有 SVG 文件，跳过（PNG 等其他格式不处理）
      next unless svg_entry

      # 构建新的 images 数组：只保留一个条目，包含 filename 和 idiom，去掉 scale
      new_image = {
        'filename' => svg_entry['filename'],
        'idiom' => 'universal'
      }

      new_images = [new_image]

      # 检查是否需要更新（避免无意义的写入）
      if contents['images'] == new_images
        skipped_count += 1
        next
      end

      # 更新 contents 并写回文件
      contents['images'] = new_images
      formatted_json = JSON.pretty_generate(contents, indent: '  ')
      # 确保末尾有换行符
      formatted_json += "\n" unless formatted_json.end_with?("\n")

      File.write(contents_file, formatted_json)
      formatted_count += 1
      UI.message("✅ 已格式化: #{contents_file}")
    end

    UI.success("格式化完成！已处理 #{formatted_count} 个 SVG imageset，跳过 #{skipped_count} 个。")
  end

end
